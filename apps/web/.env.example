# Copy this file to .env.local for local development
# API_URL: server-side runtime env var — NOT NEXT_PUBLIC_.
# Next.js rewrites /api-proxy/* → ${API_URL}/* at runtime (see next.config.ts).
# For production (Railway): set API_URL in the web service Variables tab.
# No build arg needed. Falls back to localhost:3001 if unset (local dev).
API_URL=http://localhost:3001
