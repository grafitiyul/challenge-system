{
  "name": "@challenge-system/whatsapp-bridge",
  "version": "0.1.0",
  "private": true,
  "description": "Baileys-backed WhatsApp bridge — replaces the legacy Wassenger integration. Phase 1: schema + auth store + connection lifecycle + admin status. Message ingestion + send come in Phase 2/3.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "prisma:sync": "node scripts/sync-schema.js",
    "prisma:generate": "npm run prisma:sync && prisma generate --schema=prisma/schema.prisma",
    "postinstall": "npm run prisma:generate",
    "build": "npm run prisma:generate && tsc -p tsconfig.json",
    "start": "npm run prisma:generate && node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "@prisma/client": "^6.5.0",
    "@whiskeysockets/baileys": "^6.7.18",
    "fastify": "^4.28.1",
    "pino": "^9.6.0",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/qrcode": "^1.5.5",
    "prisma": "^6.5.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.3"
  }
}
