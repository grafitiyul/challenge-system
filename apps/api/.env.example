# Database
DATABASE_URL="postgresql://user:password@host:port/dbname"

# API
API_PORT=3001
NODE_ENV=development

# Web
NEXT_PUBLIC_API_URL=http://localhost:3001

# Bypass portal opening gate (admin preview only — set a strong random secret in production)
BYPASS_SECRET=

# Admin email auth — SMTP config for OTP codes and password resets
# Leave blank to log emails to console (dev mode)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Challenge System <noreply@example.com>"

# Frontend URL used in password reset links (e.g. https://web.railway.app)
FRONTEND_URL=http://localhost:3000
